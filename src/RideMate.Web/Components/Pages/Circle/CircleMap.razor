    private sealed class MemberDetail
    {
        public string UserId { get; set; } = "";
        public string DisplayName { get; set; } = "RideMate User";
        public string AvatarUrl { get; set; } = "/favicon.png";
        public double Latitude { get; set; }
        public double Longitude { get; set; }
        public int? BatteryLevel { get; set; }
        public DateTime? LastSeen { get; set; }
        public bool IsOffline { get; set; } = true;
        public bool IsLocationPermissionDenied { get; set; }
        public bool HasLocation { get; set; }

        public string BatteryText => BatteryLevel is null ? "Battery not shared" : $"{BatteryLevel}%";

        public string LastSeenText
        {
            get
            {
                if (LastSeen is null)
                {
                    return "No ping";
                }

                var elapsed = DateTime.UtcNow - LastSeen.Value.ToUniversalTime();

                if (elapsed.TotalSeconds < 45)
                {
                    return "Now";
                }

                if (elapsed.TotalMinutes < 60)
                {
                    return $"{Math.Max(1, (int)elapsed.TotalMinutes)}m ago";
                }

                return $"{Math.Max(1, (int)elapsed.TotalHours)}h ago";
            }
        }

        public string StatusText
        {
            get
            {
                if (IsLocationPermissionDenied)
                {
                    return "Location permission denied";
                }

                if (!HasLocation)
                {
                    return "No location shared yet";
                }

                return IsOffline ? "Offline - last known location" : "Live on map";
            }
        }

        public static MemberDetail From(string userId, string displayName, string avatarUrl, LocationLog? location, bool isOnline)
        {
            var isOffline = location is null ||
                location.IsLocationPermissionDenied ||
                !isOnline;

            return new MemberDetail
            {
                UserId = userId,
                DisplayName = displayName,
                AvatarUrl = avatarUrl,
                Latitude = location?.Latitude ?? 0,
                Longitude = location?.Longitude ?? 0,
                BatteryLevel = location?.BatteryLevel,
                LastSeen = location?.Timestamp,
                IsOffline = isOffline,
                IsLocationPermissionDenied = location?.IsLocationPermissionDenied ?? false,
                HasLocation = location is not null
            };
        }
    }
