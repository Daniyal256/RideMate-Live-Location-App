    private async Task SaveProfileAsync()
    {
        if (_currentUser is null)
        {
            return;
        }

        if (string.IsNullOrWhiteSpace(_profileDisplayName))
        {
            _settingsMessage = "Name cannot be empty.";
            return;
        }

        _currentUser.DisplayName = _profileDisplayName.Trim();
        var oldAvatarUrl = _currentUser.AvatarUrl;
        string? newAvatarUrl = null;

        if (_selectedAvatar is not null)
        {
            newAvatarUrl = await SaveAvatarAsync(_selectedAvatar);

            if (newAvatarUrl is null)
            {
                return;
            }

            _currentUser.AvatarUrl = newAvatarUrl;
            _selectedAvatar = null;
        }

        var result = await UserManager.UpdateAsync(_currentUser);

        if (!result.Succeeded)
        {
            DeleteLocalAvatarFile(newAvatarUrl);
            _currentUser.AvatarUrl = oldAvatarUrl;
            _settingsMessage = result.Errors.FirstOrDefault()?.Description ?? "Profile update failed.";
            return;
        }

        if (newAvatarUrl is not null)
        {
            DeleteLocalAvatarFile(oldAvatarUrl);
        }

        UpsertMember(
            _currentUser.Id,
            DisplayName,
            AvatarUrl,
            _members.FirstOrDefault(m => m.UserId == _currentUser.Id)?.Latitude ?? DefaultLat,
            _members.FirstOrDefault(m => m.UserId == _currentUser.Id)?.Longitude ?? DefaultLng,
            DateTime.UtcNow,
            _members.FirstOrDefault(m => m.UserId == _currentUser.Id)?.BatteryLevel,
            _members.FirstOrDefault(m => m.UserId == _currentUser.Id)?.IsOffline ?? true,
            _members.FirstOrDefault(m => m.UserId == _currentUser.Id)?.IsLocationPermissionDenied ?? false);

        await RenderMemberMarkersAsync();
        _settingsMessage = "Profile updated.";
    }

    private async Task<string?> SaveAvatarAsync(IBrowserFile file)
    {
        var allowedTypes = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase)
        {
            ["image/jpeg"] = ".jpg",
            ["image/png"] = ".png",
            ["image/webp"] = ".webp",
            ["image/gif"] = ".gif"
        };

        if (!allowedTypes.TryGetValue(file.ContentType, out var extension))
        {
            _settingsMessage = "Photo must be a JPG, PNG, WebP, or GIF.";
            return null;
        }

        if (file.Size > 4 * 1024 * 1024)
        {
            _settingsMessage = "Photo must be under 4MB.";
            return null;
        }

        var uploadsPath = Path.Combine(Env.WebRootPath, "uploads");
        Directory.CreateDirectory(uploadsPath);

        var fileName = $"{Guid.NewGuid():N}{extension}";
        var filePath = Path.Combine(uploadsPath, fileName);

        await using var input = file.OpenReadStream(4 * 1024 * 1024);
        await using var output = File.Create(filePath);
        await input.CopyToAsync(output);

        return $"/uploads/{fileName}";
    }

    private async Task DeletePhotoAsync()
    {
        if (_currentUser is null)
        {
            return;
        }

        DeleteLocalAvatarFile(_currentUser.AvatarUrl);
        _currentUser.AvatarUrl = null;
        _selectedAvatar = null;

        var result = await UserManager.UpdateAsync(_currentUser);
        _settingsMessage = result.Succeeded
            ? "Profile photo deleted."
            : result.Errors.FirstOrDefault()?.Description ?? "Photo delete failed.";

        if (result.Succeeded)
        {
            var me = _members.FirstOrDefault(m => m.UserId == _currentUser.Id);

            UpsertMember(
                _currentUser.Id,
                DisplayName,
                AvatarUrl,
                me?.Latitude ?? DefaultLat,
                me?.Longitude ?? DefaultLng,
                me?.LastSeen ?? DateTime.UtcNow,
                me?.BatteryLevel,
                me?.IsOffline ?? true,
                me?.IsLocationPermissionDenied ?? false);

            await RenderMemberMarkersAsync();
        }
    }

    private void DeleteLocalAvatarFile(string? avatarUrl)
    {
        if (string.IsNullOrWhiteSpace(avatarUrl) ||
            !avatarUrl.StartsWith("/uploads/", StringComparison.OrdinalIgnoreCase))
        {
            return;
        }

        var fileName = Path.GetFileName(avatarUrl);
        var path = Path.Combine(Env.WebRootPath, "uploads", fileName);

        if (File.Exists(path))
        {
            File.Delete(path);
        }
    }

