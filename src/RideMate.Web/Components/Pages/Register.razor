@page "/register"

<div class="min-h-screen flex items-center justify-center bg-gradient-to-br from-blue-50 to-indigo-100 p-6">
    <div class="w-full max-w-md bg-white/80 backdrop-blur-lg rounded-[2rem] shadow-2xl p-10 border border-white">
        <h2 class="text-4xl font-black mb-6">Join RideMate</h2>

        @if (!string.IsNullOrWhiteSpace(Error))
        {
            <p class="mb-4 text-sm font-semibold text-red-600">
                @Error
            </p>
        }

        <form method="post" action="/auth/register" enctype="multipart/form-data" class="space-y-4">
            <input name="displayName" placeholder="Name"
                   autocomplete="name" required
                   class="w-full p-4 rounded-xl bg-slate-100" />

            <input name="email" type="email" placeholder="Email"
                   autocomplete="email" required
                   class="w-full p-4 rounded-xl bg-slate-100" />

            <input name="password" type="password" placeholder="Password"
                   autocomplete="new-password" required minlength="6"
                   class="w-full p-4 rounded-xl bg-slate-100" />

            <label class="block">
                <span class="block mb-2 text-sm font-bold text-slate-600">Profile photo</span>
                <input name="avatar" type="file" accept="image/png,image/jpeg,image/webp,image/gif"
                       class="w-full p-4 rounded-xl bg-slate-100" />
            </label>

            <button type="submit"
                    class="w-full bg-blue-600 text-white p-4 rounded-xl font-bold">
                Create Account
            </button>
        </form>

        <p class="mt-4 text-center">
            Already have an account?
            <a href="/login" class="text-blue-600">Login</a>
        </p>
    </div>
</div>

@code {
    [SupplyParameterFromQuery(Name = "error")]
    public string? Error { get; set; }
}
